<AnyLogicWorkspace WorkspaceVersion="1.9" AnyLogicVersion="8.9.3.202411201859" AlpVersion="8.9.2">
<Model>
	<Id>1700000000001</Id>
	<Name><![CDATA[Legal Process Simulation (with ONNX)]]></Name>
	<Description><![CDATA[This model simulates court/legal proceedings with AI-driven predictions.
Two ONNX neural networks drive the simulation: one predicts the filing rate of new cases based on a sliding window of recent rates; the other predicts case duration based on 8 case attributes (type, complexity, evidence count, number of parties, prior continuances, judge experience, jurisdiction, and jury trial flag).
Toggle the useAIPredictions parameter to compare AI-driven versus default stochastic behaviour.]]></Description>
	<EngineVersion>6</EngineVersion>
	<JavaPackageName><![CDATA[legal_process_simulation_onnx]]></JavaPackageName>
	<ModelTimeUnit><![CDATA[Day]]></ModelTimeUnit>
	
	<Folders>
		
	</Folders>
	<ActiveObjectClasses>
		<!--   =========   Active Object Class: Main   ========  -->
		<ActiveObjectClass>
			<Id>1700000000010</Id>
			<Name><![CDATA[Main]]></Name>
			<Import><![CDATA[import com.google.common.collect.EvictingQueue;
import java.util.stream.IntStream;]]></Import>
			<StartupCode><![CDATA[// Fill sliding window with random seed data
IntStream.range(0, 6).forEach($ -> previousFilingRates.add((float)uniform(5.0, 15.0)));
// Kick off the first AI-predicted rate
if (useAIPredictions) {
	double initialRate = predictFilingRate();
	caseIntake.set_rate(initialRate, PER_DAY);
}]]></StartupCode>
			<Generic>false</Generic>
