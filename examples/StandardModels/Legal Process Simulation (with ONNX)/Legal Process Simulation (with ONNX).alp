			<!-- ===== Functions ===== -->
			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1700000000300</Id>
					<Name><![CDATA[predictFilingRate]]></Name>
					<X>170</X><Y>100</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[// Use the previous values to predict the next.
// Note that we need to convert a Collection-typed input to a primitive one.
float[] raw_output = caseRateQuerier.predict(float[].class, previousFilingRates.toArray(new Float[6]));
float predicted_rate = Math.max(raw_output[0], 0.5f);
previousFilingRates.add(predicted_rate);
return (double)predicted_rate;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1700000000301</Id>
					<Name><![CDATA[predictCaseDuration]]></Name>
					<X>50</X><Y>100</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[c]]></Name>
						<Type><![CDATA[Case]]></Type>
					</Parameter>
					<Body><![CDATA[float[] prediction = durationQuerier.predict(float[].class, c.getFeatureArray());
return Math.max((double)prediction[0], 14.0);]]></Body>
				</Function>
			</Functions>

